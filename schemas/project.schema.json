{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://causalvideogroup.github.io/schemas/project.schema.json",
  "title": "CausalVideoGroup project metadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "slug", "status", "summary", "leaders", "tags", "links"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "status": {
      "type": "string",
      "enum": ["planned", "active", "published", "archived"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "leaders": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "short_name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "short_name": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "github": { "type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$" }
        }
      }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "paper": { "type": "string", "format": "uri" },
        "code": { "type": "string", "format": "uri" },
        "model": { "type": "string", "format": "uri" },
        "dataset": { "type": "string", "format": "uri" },
        "demo": { "type": "string", "format": "uri" }
      }
    },
    "start_date": { "type": "string", "format": "date" },
    "publication_date": { "type": "string", "format": "date" }
  }
}
